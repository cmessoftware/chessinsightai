        {
            "name": "3. LLM Reports - Batch",
            "item": [
                {
                    "name": "Generate Batch Reports - 3 Games",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Response has summary\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('total_games');",
                                    "    pm.expect(jsonData).to.have.property('successful');",
                                    "    pm.expect(jsonData).to.have.property('failed');",
                                    "    pm.expect(jsonData).to.have.property('total_cost_usd');",
                                    "    pm.expect(jsonData).to.have.property('total_tokens');",
                                    "    pm.expect(jsonData).to.have.property('reports');",
                                    "});",
                                    "",
                                    "pm.test(\"All games processed\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.total_games).to.equal(3);",
                                    "    pm.expect(jsonData.reports).to.be.an('array');",
                                    "    pm.expect(jsonData.reports.length).to.equal(3);",
                                    "});",
                                    "",
                                    "pm.test(\"Cost is tracked for batch\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.total_cost_usd).to.be.above(0);",
                                    "    pm.expect(jsonData.total_tokens).to.be.above(0);",
                                    "});",
                                    "",
                                    "// Log batch summary",
                                    "var jsonData = pm.response.json();",
                                    "console.log(\"\\n\" + \"=\".repeat(60));",
                                    "console.log(\"🧠 BATCH LLM REPORTS - SUMMARY\");",
                                    "console.log(\"=\".repeat(60));",
                                    "console.log(\"Total Games: \" + jsonData.total_games);",
                                    "console.log(\"Successful: \" + jsonData.successful);",
                                    "console.log(\"Failed: \" + jsonData.failed);",
                                    "console.log(\"Total Tokens: \" + jsonData.total_tokens);",
                                    "console.log(\"Total Cost: $\" + jsonData.total_cost_usd.toFixed(4));",
                                    "console.log(\"Avg Cost per Game: $\" + (jsonData.total_cost_usd / jsonData.total_games).toFixed(4));",
                                    "console.log(\"=\".repeat(60));",
                                    "",
                                    "// Log individual reports",
                                    "jsonData.reports.forEach((report, index) => {",
                                    "    console.log(\"\\n📄 Report #\" + (index + 1) + \":\");",
                                    "    if (report.error) {",
                                    "        console.log(\"  ❌ Error: \" + report.error);",
                                    "    } else {",
                                    "        console.log(\"  ✅ Game ID: \" + report.game_id);",
                                    "        console.log(\"  Analysis ID: \" + report.analysis_id);",
                                    "        console.log(\"  Tokens: \" + report.tokens_used.total);",
                                    "        console.log(\"  Cost: $\" + report.cost_estimate_usd.toFixed(4));",
                                    "    }",
                                    "});",
                                    "console.log(\"\\n\" + \"=\".repeat(60));"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
