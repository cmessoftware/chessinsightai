# Frontend Environment Variables
# Copiar este archivo a .env.local y configurar según el entorno

# API Base URL - Cambiar según el entorno
# Desarrollo local:
VITE_API_URL=http://127.0.0.1:8000

# Producción (ejemplo):
# VITE_API_URL=https://api.chess-trainer.com

# Staging (ejemplo):
# VITE_API_URL=https://staging-api.chess-trainer.com
