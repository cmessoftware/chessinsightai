{
    "info": {
        "_postman_id": "chess-shap-api-collection",
        "name": "Chess SHAP Analysis API",
        "description": "Colección completa para testing de SHAP Analysis endpoints",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "Login - Get Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Login successful\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.environment.set(\"token\", jsonData.access_token);",
                                    "    console.log(\"Token saved: \" + jsonData.access_token.substring(0, 20) + \"...\");",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Autenticación y obtención de JWT token"
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. SHAP Analysis - Query",
            "item": [
                {
                    "name": "Get All SHAP Values (Game 1)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Response is array\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.be.an('array');",
                                    "});",
                                    "",
                                    "pm.test(\"Contains SHAP values\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.length).to.be.above(0);",
                                    "    pm.expect(jsonData[0]).to.have.property('shap_value');",
                                    "    pm.expect(jsonData[0]).to.have.property('error_label');",
                                    "});",
                                    "",
                                    "// Mostrar distribución de error_labels",
                                    "var jsonData = pm.response.json();",
                                    "var distribution = {};",
                                    "jsonData.forEach(item => {",
                                    "    distribution[item.error_label] = (distribution[item.error_label] || 0) + 1;",
                                    "});",
                                    "console.log(\"Total SHAP values: \" + jsonData.length);",
                                    "console.log(\"Distribution:\", distribution);"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/analysis/shap/game/5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "analysis",
                                "shap",
                                "game",
                                "5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb"
                            ]
                        },
                        "description": "Obtener todos los SHAP values de un game (4,149 valores)"
                    },
                    "response": []
                },
                {
                    "name": "Get SHAP Values - Specific Move",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"All moves match move_number\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    jsonData.forEach(item => {",
                                    "        pm.expect(item.move_number).to.equal(10);",
                                    "    });",
                                    "});",
                                    "",
                                    "// Mostrar top features",
                                    "var jsonData = pm.response.json();",
                                    "console.log(\"Features count: \" + jsonData.length);",
                                    "var sorted = jsonData.sort((a, b) => Math.abs(b.shap_value) - Math.abs(a.shap_value));",
                                    "console.log(\"Top features:\");",
                                    "sorted.slice(0, 5).forEach(item => {",
                                    "    console.log(`  ${item.feature_name}: ${item.shap_value.toFixed(4)}`);",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/analysis/shap/game/5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb?move_number=10",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "analysis",
                                "shap",
                                "game",
                                "5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb"
                            ],
                            "query": [
                                {
                                    "key": "move_number",
                                    "value": "10"
                                }
                            ]
                        },
                        "description": "Obtener SHAP values de una jugada específica (9 features)"
                    },
                    "response": []
                },
                {
                    "name": "Get SHAP Values - Top N Features",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Limited to top N per move\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    var moves = {};",
                                    "    jsonData.forEach(item => {",
                                    "        moves[item.move_number] = (moves[item.move_number] || 0) + 1;",
                                    "    });",
                                    "    // Verificar que cada jugada tenga máximo 5 features",
                                    "    Object.values(moves).forEach(count => {",
                                    "        pm.expect(count).to.be.at.most(5);",
                                    "    });",
                                    "});",
                                    "",
                                    "var jsonData = pm.response.json();",
                                    "var moves = {};",
                                    "jsonData.forEach(item => {",
                                    "    moves[item.move_number] = (moves[item.move_number] || 0) + 1;",
                                    "});",
                                    "console.log(\"Total SHAP values: \" + jsonData.length);",
                                    "console.log(\"Unique moves: \" + Object.keys(moves).length);",
                                    "console.log(\"Features per move: \" + (jsonData.length / Object.keys(moves).length));"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/analysis/shap/game/5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb?top_n=5",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "analysis",
                                "shap",
                                "game",
                                "5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb"
                            ],
                            "query": [
                                {
                                    "key": "top_n",
                                    "value": "5"
                                }
                            ]
                        },
                        "description": "Obtener top 5 features por cada jugada (2,305 valores)"
                    },
                    "response": []
                },
