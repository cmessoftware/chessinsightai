        {
            "name": "3. SHAP Analysis - Run New",
            "item": [
                {
                    "name": "Run SHAP Analysis",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Analysis completed\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('analysis_id');",
                                    "    pm.expect(jsonData).to.have.property('status');",
                                    "});",
                                    "",
                                    "var jsonData = pm.response.json();",
                                    "console.log(\"Analysis ID: \" + jsonData.analysis_id);",
                                    "console.log(\"Status: \" + jsonData.status);",
                                    "if (jsonData.shap_values_count) {",
                                    "    console.log(\"SHAP values created: \" + jsonData.shap_values_count);",
                                    "}",
                                    "if (jsonData.error_distribution) {",
                                    "    console.log(\"Error distribution:\", jsonData.error_distribution);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"game_id\": \"5daf60d3cfe938edbe083c9bd584b6a62b27c1068d927cf3d35875479f4006bb\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/analysis/run",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "analysis",
                                "run"
                            ]
                        },
                        "description": "Ejecutar nuevo análisis SHAP en un game"
                    },
                    "response": []
                }
            ]
